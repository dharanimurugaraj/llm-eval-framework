# LLM Providers
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here_if_cloud
QDRANT_COLLECTION_NAME=llm_eval_docs

# Experiment Tracking
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=llm-eval-framework
WANDB_ENTITY=your_wandb_username_here

# Evaluation Settings
EVAL_DATASET_PATH=data/processed/eval_dataset.json
EVAL_RESULTS_PATH=data/processed/eval_results.json
MIN_FAITHFULNESS_THRESHOLD=0.7
MIN_ANSWER_RELEVANCE_THRESHOLD=0.7
MIN_CONTEXT_RECALL_THRESHOLD=0.6

# App Settings
APP_ENV=development
LOG_LEVEL=INFO
